# AptTrack Environment Configuration
# Copy this file to .env and modify values as needed

# Database Configuration
DATABASE_URL=postgresql://user:password@db:5432/rental_tracker
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=rental_tracker
DATABASE_USER=user
DATABASE_PASSWORD=password

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# Frontend Configuration
FRONTEND_PORT=3000
FRONTEND_HOST=localhost

# API Configuration
API_BASE_URL=http://localhost:8000/api/v1
API_VERSION=v1

# External Services
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
MINIMAX_API_KEY=your_minimax_api_key_here
SCRAPE_INTERVAL_MINUTES=60

# JWT Authentication (generate a strong random key for production)
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Notifications (optional)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@apttrack.app
# ECDSA public key from SendGrid dashboard → Settings → Mail Settings → Event Webhook.
# Leave empty to skip webhook signature verification (dev/test only).
SENDGRID_WEBHOOK_VERIFICATION_KEY=
TELEGRAM_BOT_TOKEN=
# chat_id for nightly scrape-digest Telegram messages (optional)
TELEGRAM_ADMIN_CHAT_ID=

# Email CTA links (used in price alert + welcome email; no trailing slash)
APP_BASE_URL=https://apttrack.up.railway.app

# Demo subscription created on user register
DEFAULT_DEMO_CITY=San Jose

# Development Configuration
NODE_ENV=development
PYTHON_ENV=development

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Logging
LOG_LEVEL=INFO
